# ============================================================
# Life Dashboard — Fase 1 config (alles via env vars)
# Kopieer naar .env en pas aan. Niets hierin is geheim behalve
# OPENROUTER_API_KEY.
# ============================================================

# --- Vault: de bron van waarheid is een MAP MET MARKDOWN ---
# Hoe die map gesynct wordt (Syncthing / Obsidian Sync / git / NAS-share)
# staat los van het dashboard. Het dashboard leest/schrijft enkel dit pad.
VAULT_PATH=./sample-vault
# Submap waarin dagnotities staan (YYYY-MM-DD.md).
DAILY_SUBDIR=Daily

# --- Agenda-ingest (beide bronnen ondersteund; bestand eerst) ---
# Een .ics-bestand OF een map met .ics-bestanden binnen de vault.
ICS_FILE=./sample-vault/Calendar/life.ics
# Optionele live ICS-abonnement-URL (laat leeg om alleen het bestand te gebruiken).
ICS_URL=

# --- Index: herbouwbare cache (NIET de bron) ---
# Staat bewust BUITEN de vault — je mag dit bestand altijd weggooien.
INDEX_DB=./data/index.db
# Bij opstart de index opbouwen als die leeg is.
AUTO_REBUILD_ON_START=true
# Periodiek pollen voor veranderingen in de vault (seconden). 0 = uit.
# Bij verandering wordt de index automatisch herbouwd.
AUTO_REBUILD_POLL_SECONDS=300

# --- Locale / tijd ---
DASHBOARD_TZ=Europe/Amsterdam

# --- AI-briefings via OpenRouter (provider-wisselbaar) ---
# Laat OPENROUTER_API_KEY leeg om zonder AI te draaien (placeholder-briefing).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-haiku
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REFERER=http://localhost
OPENROUTER_TITLE=Life Dashboard

# --- Server / UI ---
PORT=8765
# Volledige page-reload-interval (uren) tegen geheugenlekken op de TV.
RELOAD_INTERVAL_HOURS=3
# Thema's voor het dropdownetje bij het logveld.
LOG_THEMES=algemeen,werk,gezondheid,idee,relatie
DEFAULT_THEME=algemeen
# Hoeveel recente logs het dashboard toont.
RECENT_LOGS_COUNT=10
# CORS-origins (komma-gescheiden, of * ). Phase 1 draait achter je LAN/Tailscale.
CORS_ORIGINS=*
